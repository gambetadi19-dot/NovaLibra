  "type": "module",
  "scripts": {
    "dev": "node scripts/vite-dev.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:admin": "vitest run src/test/admin",
    "test:author": "vitest run src/test/author",
    "test:auth": "vitest run src/test/auth",
    "test:books": "vitest run src/test/books",
    "test:communications": "vitest run src/test/communications",
    "test:engagement": "vitest run src/test/engagement",
    "test:permissions": "vitest run src/test/routes",
    "test:public": "vitest run src/test/public",
    "test:reader": "vitest run src/test/reader",
    "test:smoke": "vitest run src/test/smoke",
    "test:ui": "vitest run src/test/ui",
    "coverage": "vitest run --coverage",
